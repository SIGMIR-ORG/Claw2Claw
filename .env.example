# Root scripts
CLAW2CLAW_HOST=127.0.0.1

# Registry defaults
SERVER_PORT=8080
SERVER_DB_PATH=./server/data/registry.db
SERVER_HEARTBEAT_INTERVAL_SECONDS=45
SERVER_HEARTBEAT_TTL_SECONDS=135
SERVER_ALLOW_SELF_ATTESTED=true
SERVER_REQUIRE_HTTPS_FOR_PUBLIC=false

# Sidecar defaults
SIDECAR_HOST=127.0.0.1
SIDECAR_PORT=8090
SIDECAR_PUBLIC_ORIGIN=http://127.0.0.1:8090
SIDECAR_OPENCLAW_BASE_URL=http://127.0.0.1:3000
SIDECAR_REGISTRY_URL=http://127.0.0.1:8080
SIDECAR_AUTO_REGISTER=false
SIDECAR_AGENT_NAME=claw2claw-sidecar
SIDECAR_AGENT_DESCRIPTION=Local OpenClaw sidecar
SIDECAR_AGENT_VERSION=0.1.0
SIDECAR_SIGNING_KEY_ID=main
SIDECAR_VISIBILITY=private
SIDECAR_OWNER_TYPE=service
SIDECAR_ACCEPTS_DELEGATION=false
SIDECAR_REQUIRES_APPROVAL_FOR_SENSITIVE_ACTIONS=true
SIDECAR_REGION=local
SIDECAR_LANGUAGES=en
SIDECAR_TAGS=local
SIDECAR_PUBLIC_SKILLS=research.summarize
A2A_BEARER_TOKEN=dev-bearer-token-change-me
SIDECAR_SIGNING_SEED_HEX=000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f
