{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://claw2claw.cc/spec/claw-profile.schema.json",
  "title": "Claw2Claw Profile",
  "description": "Registry-owned metadata for Claw2Claw discovery, trust filtering, and local policy hints.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "visibility",
    "ownerType",
    "acceptsDelegation",
    "requiresApprovalForSensitiveActions",
    "relayRequired",
    "region",
    "languages",
    "tags"
  ],
  "properties": {
    "visibility": {
      "type": "string",
      "enum": ["public", "private"]
    },
    "trustTier": {
      "type": "string",
      "enum": ["self_attested", "domain_verified", "manually_verified"]
    },
    "ownerType": {
      "type": "string",
      "enum": ["personal", "organization", "service"]
    },
    "acceptsDelegation": {
      "type": "boolean"
    },
    "requiresApprovalForSensitiveActions": {
      "type": "boolean"
    },
    "relayRequired": {
      "type": "boolean",
      "const": false
    },
    "region": {
      "type": "string",
      "minLength": 2,
      "maxLength": 16
    },
    "languages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 2,
        "maxLength": 16
      },
      "uniqueItems": true
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 64
      },
      "uniqueItems": true
    }
  }
}
